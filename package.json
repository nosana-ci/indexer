{
  "name": "app",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "db:generate": "drizzle-kit generate --config=config/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=config/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=config/drizzle.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci:test": "vitest run --reporter=default --reporter=junit --outputFile.junit=./junit.xml",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test:scenarios": "vitest run --config tests/scenario/vitest.scenarios.config.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/cron": "^1.4.1",
    "@elysiajs/swagger": "1.3.1",
    "@nosana/kit": "^2.1.7",
    "@sinclair/typebox": "^0.34.48",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "elysia": "1.4.22",
    "elysia-rate-limit": "^4.5.0",
    "openapi-types": "^12.1.3",
    "pg": "^8.18.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bs58": "^4.0.4",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "8.57.0",
    "@typescript-eslint/parser": "8.57.0",
    "@vitest/coverage-v8": "^4.0.18",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.8",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "pino-pretty": "^13.1.3",
    "prettier": "3.8.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "8.57.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "module": "src/index.js"
}
