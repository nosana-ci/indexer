{
  "name": "app",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "db:generate": "drizzle-kit generate --config=config/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=config/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=config/drizzle.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci:test": "vitest run --reporter=default --reporter=junit --outputFile.junit=./junit.xml"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/cron": "^1.4.1",
    "@elysiajs/swagger": "1.3.1",
    "@nosana/kit": "^2.1.7",
    "@sinclair/typebox": "^0.34.48",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "elysia": "1.4.22",
    "elysia-rate-limit": "^4.5.0",
    "openapi-types": "^12.1.3",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/bs58": "^4.0.4",
    "@types/pg": "^8.16.0",
    "@vitest/coverage-v8": "^4.0.18",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  },
  "module": "src/index.js"
}
